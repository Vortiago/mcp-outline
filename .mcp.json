{
  "mcpServers": {
    "outline": {
      "command": "uvx",
      "args": ["mcp-outline"],
      "env": {
        "OUTLINE_API_KEY": "${OUTLINE_API_KEY}",
        "OUTLINE_API_URL": "${OUTLINE_API_URL:-https://app.getoutline.com/api}",
        "OUTLINE_READ_ONLY": "${OUTLINE_READ_ONLY:-}",
        "OUTLINE_DISABLE_DELETE": "${OUTLINE_DISABLE_DELETE:-}",
        "OUTLINE_DISABLE_AI_TOOLS": "${OUTLINE_DISABLE_AI_TOOLS:-}",
        "OUTLINE_VERIFY_SSL": "${OUTLINE_VERIFY_SSL:-true}"
      }
    }
  }
}
